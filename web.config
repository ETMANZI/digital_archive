<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <handlers>
            <add name="Django FastCGI" path="*" verb="*" modules="FastCgiModule" scriptProcessor="C:\inetpub\wwwroot\digital_archive\venv\Scripts\python.exe|C:\inetpub\wwwroot\digital_archive\venv\Lib\site-packages\wfastcgi.py" resourceType="Unspecified" requireAccess="Script" />
        </handlers>
        <defaultDocument enabled="false" />
        <directoryBrowse enabled="false" />


        <security>
            <requestFiltering>
                <requestLimits maxAllowedContentLength="524288000" />
            </requestFiltering>
        </security>

    </system.webServer>
    <appSettings>
        <add key="WSGI_HANDLER" value="dam.wsgi.application" />
        <add key="PYTHONPATH" value="C:\inetpub\wwwroot\digital_archive" />
        <add key="DJANGO_SETTINGS_MODULE" value="dam.settings" />
    </appSettings>
</configuration>